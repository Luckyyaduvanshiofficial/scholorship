# Tamboli Samaj Portal — Environment Configuration
# Copy this file to .env and fill in values

# Application
APP_NAME="Tamboli Samaj Portal"
APP_URL=https://portal.tambolisamaj.online
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_SECRET=change-this-to-a-random-64-char-string

# Host identifier for multi-site routing (overridden by each entry point index.php)
# Values: 'site' (main website), 'portal' (student portal), 'admin' (admin panel)
APP_HOST=portal

# Multi-site URLs (Hostinger production)
SITE_URL=https://tambolisamaj.online
PORTAL_URL=https://portal.tambolisamaj.online
ADMIN_URL=https://admin.tambolisamaj.online

# Cross-subdomain session cookie (empty for local dev; .tambolisamaj.online in production)
SESSION_DOMAIN=.tambolisamaj.online

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u990971317_tsp
DB_USER=u990971317_tsp_admin
DB_PASS=


# Session
SESSION_LIFETIME=86400
SESSION_SECURE=false
SESSION_NAME=TSP_SESSION

# Mail / SMTP Settings
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@yourdomain.com
SMTP_PASS=your-mailbox-password
SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME="Tamboli Samaj Portal"
