DirectoryIndex index.php
Options -Indexes +FollowSymLinks

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct web access to application internals
    RewriteRule ^(app|vendor|storage|database|uploads|\.git|\.commandcode|docs)(/|$) - [F,L]

    # Unified doc root: allow /assets → portal/assets (Mode B fallback)
    RewriteRule ^assets/(.*)$ portal/assets/$1 [L]
    RewriteRule ^uploads/(.*)$ portal/uploads/$1 [L]

    # Route dynamic requests to root index.php (auto-detects site/portal/admin host)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Deny sensitive files at project root
<FilesMatch "^(\.env|\.env\.example|composer\.(json|lock)|\.gitignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>